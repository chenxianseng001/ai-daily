# AI Daily — 环境变量配置
#
# 复制为 .env 后使用。
# 所有配置项均为可选项。

# AI 摘要
AI_SUMMARY_API_KEY=""              # OpenAI / DeepSeek 等 API Key
AI_SUMMARY_PROVIDER="openai"       # provider: openai/deepseek/ollama etc.
AI_SUMMARY_MODEL=""                # model（留空使用默认值）

# GitHub Token（可选，提升 API 配额）
GITHUB_TOKEN=""

# Product Hunt Token（可选，启用 GraphQL API 获取完整数据）
PRODUCT_HUNT_TOKEN=""
