# AI Daily — 环境变量配置模板
#
# 复制为 .env 后使用。
# 所有配置项均为可选项。

# AI 摘要（必需：至少配置一个 LLM API Key）
AI_SUMMARY_PROVIDER=openai
#  可选值: openai / deepseek / openrouter / ollama / lm_studio / siliconflow / gemini / claude
AI_SUMMARY_MODEL=
#  留空使用 Provider 默认值
AI_SUMMARY_API_KEY=your_api_key_here

# 飞书投递（可选）
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_HOME_CHANNEL=your_feishu_chat_id

# GitHub Token（可选，提升 API 配额至 5000 req/h）
GITHUB_TOKEN=

# Product Hunt Token（可选，启用 GraphQL API）
PRODUCT_HUNT_TOKEN=
